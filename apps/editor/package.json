{
  "name": "@monorepo/editor",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "electron-builder build",
    "test": "playwright test"
  },
  "build": {
    "appId": "com.monorepo.editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@monorepo/animation-engine": "*",
    "@monorepo/renderer": "*",
    "@monorepo/scene-graph": "*",
    "@monorepo/serialization": "*",
    "lucide-react": "^0.279.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.15",
    "electron": "25.3.0",
    "electron-builder": "^24.6.4",
    "playwright": "^1.61.1",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.3.3",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.28.0"
  }
}
