{
  "name": "@monorepo/editor",
  "version": "1.0.0",
  "description": "Unified Editor",
  "author": "Jules",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "package": "electron-builder build --mac --win --linux"
  },
  "build": {
    "appId": "com.monorepo.editor",
    "electronVersion": "25.3.0",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@monorepo/animation-engine": "*",
    "@monorepo/renderer": "*",
    "@monorepo/scene-graph": "*",
    "@monorepo/serialization": "*",
    "lucide-react": "^0.279.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.15",
    "electron": "^25.3.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.3.3",
    "vite": "^5.4.21"
  }
}
