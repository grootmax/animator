{
  "name": "@monorepo/editor",
  "version": "1.0.0",
  "description": "Desktop Editor",
  "author": "Acme Corp",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "echo 'Building Renderer...' && tsc -b && vite build",
    "build:main": "echo 'Building Main...' && npx esbuild electron/main.ts --bundle --platform=node --external:electron --outfile=dist-electron/main.js",
    "build:preload": "echo 'Building Preload...' && npx esbuild electron/preload.ts --bundle --platform=node --external:electron --outfile=dist-electron/preload.js",
    "package": "electron-builder build --linux"
  },
  "build": {
    "appId": "com.monorepo.editor",
    "electronVersion": "25.3.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@monorepo/animation-engine": "*",
    "@monorepo/renderer": "*",
    "@monorepo/scene-graph": "*",
    "@monorepo/serialization": "*",
    "lucide-react": "^0.279.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.15",
    "electron": "^25.3.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.3.3",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.28.0"
  }
}
