{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "types": {
      "dependsOn": ["^types"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "assets": {
      "dependsOn": ["types", "^assets"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "main": {
      "dependsOn": ["assets", "^main"],
      "outputs": ["dist-electron/**"]
    },
    "build": {
      "dependsOn": ["types", "assets", "main", "^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["release/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {}
  }
}
