{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["release/**"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
